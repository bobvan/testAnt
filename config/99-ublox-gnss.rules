# Stable symlinks for the two u-blox F9T GNSS receivers.
# Matched by physical USB port (ID_PATH), not by enumeration order,
# so /dev/gnss-top and /dev/gnss-bot are stable across reboots and replugs.
#
# Physical layout (identified by unplugging each in turn):
#   xhci-hcd.1 / usb-0:2  →  BOT  (lower receiver, currently ttyACM0)
#   xhci-hcd.0 / usb-0:2  →  TOP  (upper receiver, currently ttyACM1)
#
# To re-identify: watch `ls /dev/serial/by-path/` while unplugging each receiver.
# To verify a path:  udevadm info /dev/ttyACM0 | grep ID_PATH

SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="1546", \
  ENV{ID_MODEL_ID}=="01a9", \
  ENV{ID_PATH}=="platform-xhci-hcd.1-usb-0:2:1.0", \
  SYMLINK+="gnss-bot", \
  MODE="0664", \
  GROUP="dialout"

SUBSYSTEM=="tty", \
  ENV{ID_VENDOR_ID}=="1546", \
  ENV{ID_MODEL_ID}=="01a9", \
  ENV{ID_PATH}=="platform-xhci-hcd.0-usb-0:2:1.0", \
  SYMLINK+="gnss-top", \
  MODE="0664", \
  GROUP="dialout"
